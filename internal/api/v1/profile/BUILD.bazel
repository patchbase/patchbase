load("//third_party/bazel:go_rules.bzl", "go_api_library", "integration_test")

go_api_library(
    name = "profile",
    srcs = ["profile.go"],
    importpath = "go.patchbase.net/server/internal/api/v1/profile",
    visibility = ["//:__subpackages__"],
    deps = [
        "//internal/api/auth",
        "//internal/api/webutil",
        "//internal/apperr",
        "//internal/services",
        "//internal/sql",
