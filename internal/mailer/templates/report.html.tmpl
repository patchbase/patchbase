<!DOCTYPE html>
<html>
<head>
<style>
body { font-family: "Inter", -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; background-color: #0a0c10; color: #e8eaed; padding: 20px; }
.card { background-color: #161922; border-radius: 8px; padding: 20px; border: 1px solid #1e2330; }
h1 { color: #e8eaed; font-size: 24px; margin-top: 0; }
.stats { display: flex; gap: 16px; margin-bottom: 24px; flex-wrap: wrap; }
.stat-box { background-color: #111318; padding: 16px; border-radius: 6px; border: 1px solid #2a2e3d; flex: 1; min-width: 120px; }
.stat-val { font-size: 24px; font-weight: bold; }
.stat-label { font-size: 14px; color: #9ca3af; margin-top: 4px; }
table { width: 100%; border-collapse: collapse; margin-top: 16px; }
th, td { text-align: left; padding: 12px; border-bottom: 1px solid #1e2330; }
th { color: #9ca3af; font-size: 14px; }
.c-red { color: #f87171; }
.c-orange { color: #fb923c; }
.c-yellow { color: #fbbf24; }
.c-green { color: #34d399; }
</style>
</head>
<body>
<div class="card">
  <h1>Daily PatchBase Report</h1>
  <div class="stats">
    <div class="stat-box">
      <div class="stat-val">{{ .TotalHosts }}</div>
      <div class="stat-label">Total Hosts</div>
    </div>
    <div class="stat-box">
      <div class="stat-val c-red">{{ .WithCritical }}</div>
      <div class="stat-label">Critical</div>
    </div>
    <div class="stat-box">
      <div class="stat-val c-orange">{{ .WithImportant }}</div>
      <div class="stat-label">Important</div>
    </div>
    <div class="stat-box">
      <div class="stat-val c-yellow">{{ .WithMedium }}</div>
      <div class="stat-label">Medium</div>
    </div>
  </div>
  <h2>Top Hosts</h2>
  <table>
    <tr><th>Hostname</th><th>Critical</th><th>Important</th><th>Medium</th></tr>
    {{- range .TopHosts }}
    <tr>
      <td>{{ .Hostname }}</td>
      <td class="{{ if gt .CriticalCount 0 }}c-red{{ else }}c-green{{ end }}">{{ .CriticalCount }}</td>
      <td class="{{ if gt .ImportantCount 0 }}c-orange{{ else }}c-green{{ end }}">{{ .ImportantCount }}</td>
      <td class="{{ if gt .ModerateCount 0 }}c-yellow{{ else }}c-green{{ end }}">{{ .ModerateCount }}</td>
    </tr>
    {{- end }}
  </table>
</div>
</body>
</html>
